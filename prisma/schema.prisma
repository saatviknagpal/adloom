generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id         String     @id @default(cuid())
  status     String     @default("chatting") // chatting | script_approved | keyframes_review | keyframes_approved | generating | done | failed
  brief      String?    // JSON: basic_copy-shaped brief after approve
  beats      String?    // JSON: { scenes } for keyframe beatIndex alignment (derived from brief at approve)
  draftBrief String?    @default("{}") // JSON: accumulated basic_copy fields during discovery (pre-approve)
  regions    String     @default("[\"US\",\"IN\",\"CN\"]") // JSON array of selected regions
  error      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  messages   Message[]
  assets     Asset[]
  snapshots  Snapshot[]
}

model Snapshot {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  version   Int
  label     String?
  content   String   // JSON: { label, scenes, characters } from commit_script_version
  selected  Boolean  @default(false)
  messageId String?
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String   // user | assistant | system
  content   String
  imageUrl  String?  // product image if attached
  createdAt DateTime @default(now())
}

model Asset {
  id               String   @id @default(cuid())
  sessionId        String
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kind             String   // product_image | character | keyframe | video | voiceover | music | preview
  region           String?  // US | IN | CN — null for shared assets like product_image
  shotIndex        Int?     // which beat/shot this belongs to
  version          Int      @default(1)
  groupKey         String?  // stable key across versions of a character (e.g. "barista")
  selected         Boolean  @default(false) // user's chosen version within a group
  uri              String?  // null while generationStatus is pending
  generationStatus String   @default("ready") // pending | ready | failed
  generationError  String?
  prompt           String?  // the prompt used to generate this asset
  meta             String?  // JSON: extra metadata
  createdAt        DateTime @default(now())
}
